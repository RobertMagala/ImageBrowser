<Window x:Class="ImageBrowser.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ImageBrowser"
        xmlns:vwp="clr-namespace:WpfToolkit.Controls;assembly=VirtualizingWrapPanel"
        mc:Ignorable="d"
        Title="Image Browser"
        Height="600"
        Width="1000"
        KeyDown="Window_KeyDown">

    <DockPanel>

        <!-- Menu -->
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="_File">
                <MenuItem Header="_Open Folder..."
                  Click="OpenFolder_Click"/>
                <Separator/>
                <MenuItem Header="_Exit"
                  Click="Exit_Click"/>
            </MenuItem>

            <MenuItem Header="_Options">
                <MenuItem Header="Preferences..." Click="OpenPreferences_Click"/>
            </MenuItem>
        </Menu>

        <!-- Status Bar (must be direct child of DockPanel) -->
        <StatusBar DockPanel.Dock="Bottom">
            <StatusBarItem>
                <TextBlock>
                    <Run Text="Processed: "/>
                    <Run Text="{Binding ProcessedCount}"/>
                    <Run Text=" / "/>
                    <Run Text="{Binding TotalCount}"/>
                </TextBlock>
            </StatusBarItem>

            <Separator/>

            <StatusBarItem>
                <TextBlock>
                    <Run Text="Remaining: "/>
                    <Run Text="{Binding RemainingCount, Mode=OneWay}"/>
                </TextBlock>
            </StatusBarItem>

            <Separator/>
            
            <StatusBarItem>
                <TextBlock>
        <Run Text="Preview Size: "/>
        <Run Text="{Binding ThumbnailSize}"/>
        <Run Text="px"/>
                </TextBlock>
            </StatusBarItem>

        </StatusBar>

        <!-- Main Content -->
        <Grid Background="{Binding BackgroundBrush}">
            <ListBox x:Name="ThumbnailList"
                     ItemsSource="{Binding Images}"
                     ScrollViewer.CanContentScroll="True"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                     VirtualizingPanel.IsVirtualizing="True"
                     VirtualizingPanel.VirtualizationMode="Recycling"
                     HorizontalContentAlignment="Left"
                     BorderThickness="0"
                     Background="Transparent">

                <ListBox.ItemsPanel>
                    <ItemsPanelTemplate>
                        <vwp:VirtualizingWrapPanel
                            Orientation="Horizontal"
                            StretchItems="False"
                            SpacingMode="Uniform"/>
                    </ItemsPanelTemplate>
                </ListBox.ItemsPanel>

                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Padding" Value="0"/>
                        <Setter Property="Margin" Value="0"/>
                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        <Setter Property="VerticalContentAlignment" Value="Stretch"/>

                        <Setter Property="Width"
                Value="{Binding DataContext.ThumbnailSize, ElementName=ThumbnailList}"/>
                        <Setter Property="Height"
                Value="{Binding DataContext.ThumbnailSize, ElementName=ThumbnailList}"/>
                    </Style>
                </ListBox.ItemContainerStyle>

                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Border Margin="5"
                                Background="{Binding DataContext.BackgroundBrush, ElementName=ThumbnailList}">

                            <Image Source="{Binding Thumbnail}"
                                   Stretch="Uniform"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center">

                                <Image.InputBindings>
                                    <MouseBinding Gesture="LeftClick"
                                        Command="{Binding DataContext.OpenImageCommand,
                                            ElementName=ThumbnailList}"
                                        CommandParameter="{Binding FilePath}" />
                                </Image.InputBindings>

                            </Image>

                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>

            </ListBox>

        </Grid>
    </DockPanel>
</Window>